{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "agent": {
    "grill-me": {
      "description": "Interview the user relentlessly about a plan or design until reaching shared understanding",
      "mode": "primary",
      "color": "#e74c3c",
      "prompt": "Interview me relentlessly about every aspect of this plan until we reach a shared understanding. Walk down each branch of the design tree resolving dependencies between decisions one by one. If a question can be answered by exploring the codebase, explore the codebase instead. For each question, provide your recommended answer.",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  }
}
